# ─── Supabase (required) ────────────────────────────────────────────────────
# Find these in your Supabase project → Settings → API

# Public anon key — safe to expose to the browser
NEXT_PUBLIC_SUPABASE_URL=https://your-project-ref.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your-anon-key-here

# Service role key — SERVER SIDE ONLY. NEVER expose to browser.
# Used for admin operations that bypass RLS (audit log writes, storage admin)
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key-here

# ─── Application (required) ──────────────────────────────────────────────────

# Base URL of your deployed application (no trailing slash)
NEXT_PUBLIC_APP_URL=http://localhost:3000

# ─── Supabase Storage ────────────────────────────────────────────────────────
# These bucket names must match what you created in Supabase Storage

SUPABASE_STORAGE_BUCKET_PAYMENT_SLIPS=payment-slips

# ─── Optional overrides ──────────────────────────────────────────────────────

# Uncomment to enable verbose query logging in development
# NEXT_PUBLIC_DEBUG_QUERIES=true

# Node environment (set automatically by Vercel/Next.js)
# NODE_ENV=development
